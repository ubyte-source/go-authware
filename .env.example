# ── go-authware Configuration ─────────────────────────────────
#
# Copy this file to .env and configure your authentication settings.
# The library auto-discovers JWKS URLs via OpenID Connect discovery
# when AUTH_OAUTH_JWKS_URL is not set — works with any OIDC provider.

# ── Authentication Mode ──────────────────────────────────────
# Supported: none | bearer | apikey | oauth
AUTH_MODE=oauth

# ── General ──────────────────────────────────────────────────
# Realm used in WWW-Authenticate challenge headers (default: restricted)
# AUTH_REALM=restricted

# ── Bearer Token ─────────────────────────────────────────────
# Static token for simple deployments.
# AUTH_BEARER_TOKEN=my-secret-token

# ── API Key ──────────────────────────────────────────────────
# Static key validated via custom header or Authorization: ApiKey <key>.
# AUTH_API_KEY=my-api-key
# AUTH_API_KEY_HEADER=X-API-Key

# ── OAuth / JWT ──────────────────────────────────────────────
# Required: issuer URL (used for OIDC auto-discovery and iss claim validation)
AUTH_OAUTH_ISSUER=https://accounts.google.com

# Optional: audience (validated against aud claim)
AUTH_OAUTH_AUDIENCE=my-app

# Optional: JWKS URL (auto-discovered from issuer via OIDC if not set)
# AUTH_OAUTH_JWKS_URL=https://www.googleapis.com/oauth2/v3/certs

# Optional: HMAC shared secret (for testing only — use JWKS in production)
# AUTH_OAUTH_HMAC_SECRET=my-hmac-secret

# Optional: required scopes (comma-separated)
# AUTH_OAUTH_REQUIRED_SCOPES=read,write

# Optional: OAuth Proxy (MCP 2025-11-25 DCR shim)
# AUTH_OAUTH_CLIENT_ID=my-app-client-id
# AUTH_OAUTH_CLIENT_SECRET=my-app-client-secret

# Optional: RFC 9728 Protected Resource Metadata
# AUTH_OAUTH_RESOURCE=https://api.example.com
# AUTH_OAUTH_RESOURCE_DOCUMENTATION=https://docs.example.com
# AUTH_OAUTH_RESOURCE_NAME=My API
# AUTH_OAUTH_AUTHORIZATION_SERVERS=https://accounts.google.com

# ── Nginx Auth Check Server ─────────────────────────────────
# Address for the standalone auth-check binary (cmd/authcheck).
AUTH_CHECK_LISTEN=:9090

# ── Provider Examples ────────────────────────────────────────
#
# Google:
#   AUTH_OAUTH_ISSUER=https://accounts.google.com
#   AUTH_OAUTH_AUDIENCE=your-client-id.apps.googleusercontent.com
#
# Auth0:
#   AUTH_OAUTH_ISSUER=https://your-tenant.auth0.com/
#   AUTH_OAUTH_AUDIENCE=https://your-api.example.com
#
# Keycloak:
#   AUTH_OAUTH_ISSUER=https://keycloak.example.com/realms/your-realm
#   AUTH_OAUTH_AUDIENCE=your-client-id
#
# Azure AD:
#   AUTH_OAUTH_ISSUER=https://login.microsoftonline.com/{tenant}/v2.0
#   AUTH_OAUTH_AUDIENCE=api://your-app-id
#
# Okta:
#   AUTH_OAUTH_ISSUER=https://your-org.okta.com/oauth2/default
#   AUTH_OAUTH_AUDIENCE=api://default
#
# Anthropic (MCP):
#   AUTH_OAUTH_ISSUER=https://auth.anthropic.com
#   AUTH_OAUTH_AUDIENCE=your-mcp-server
